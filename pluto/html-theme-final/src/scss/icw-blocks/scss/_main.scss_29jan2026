.theme-section {
    position: relative;
    z-index: 1;
    padding-top: 5rem;
    padding-bottom: 5rem;

    @media (max-width: 992px) {
        padding-top: 3.5rem;
        padding-bottom: 3.5rem;
    }

    &.bg-none:not(.bg-custom) {
        background-image: none !important;
    }


    &.with-top-curve {
        padding-top: 1rem !important;
        z-index: 2;
        overflow: unset;

        &::before {
            content: "";
            position: absolute;
            top: -8.5rem;
            left: 0;
            width: 100%;
            height: 16.875rem;
            clip-path: ellipse(60% 100% at bottom);
            background-color: var(--light-yellow);
            z-index: -1;

            @media (max-width: 992px) {
                top: -6rem;
                left: 0;
                width: 100%;
                height: 12rem;
            }

            @media (max-width: 767px) {
                top: -3.5rem;
                left: 0;
                width: 100%;
                height: 5rem;
            }
        }

        &.bg-white {
            &::before {
                background-color: var(--white);
            }
        }
    }

    &.with-top-reverse-curve {
        overflow: unset;

        &::before {
            content: "";
            position: absolute;
            top: -8rem;
            left: 0;
            width: 100%;
            height: 15rem;
            clip-path: ellipse(60% 100% at top);
            background-color: var(--light-yellow);
            z-index: -1;

            @media (max-width: 992px) {
                top: -6rem;
                left: 0;
                width: 100%;
                height: 12rem;
            }

            @media (max-width: 767px) {
                top: -4.5rem;
                left: 0;
                width: 100%;
                height: 8rem;
            }
        }
    }

    &.with-dark-plus-bg {
        background-image: url('../../images/pluto-images/img-bg-plus-dark-vector.svg');
        background-repeat: repeat;
        background-size: contain;
        background-position: center top;
    }

    &.theme-section:has(+ .with-top-curve) {
        padding-bottom: 12rem;

        @media (max-width: 992px) {
            padding-bottom: 9rem;
        }

        @media (max-width: 767px) {
            padding-bottom: 5rem;
        }
    }
}

// Section Title CSS
.section-title {
    margin-bottom: 4.5rem;

    @media (max-width: 992px) {
        margin-bottom: 2rem;
    }


    h1,
    h2,
    h3 {
        margin-bottom: 1.5rem;

        @media (max-width: 1200px) {
            br {
                display: none;
            }
        }
    }


    & *:last-child {
        margin-bottom: 0px !important;
    }
}

.page-header {

    .section-title {
        margin: 0 auto;
        text-align: center;

        .tag-line {
            margin-bottom: 1.5rem;
            color: var(--red);
            font-weight: 800;
            font-size: 1.5rem;

            @media (max-width: 767px) {
                margin-bottom: 1rem;
                font-size: 0.875rem;

            }
        }

        h1,
        h2 {
            margin-bottom: 1.5rem;

            @media (max-width: 767px) {
                margin-bottom: 1rem;
            }
        }

        .sort-info {
            font-weight: 300;
            font-size: 1.5rem;

            @media (max-width: 767px) {
                font-size: 1rem;
            }
        }
    }

    .action {
        margin-top: 2rem;

        @media (max-width: 767px) {
            font-size: 1rem;

            .btn {
                // width: 100%;
            }
        }
    }

    & *:last-child {
        margin-bottom: 0px !important;
    }

    &.with-vector {
        @media (max-width: 992px) {
            overflow: hidden;
        }

        &::before {
            content: '';
            background-image: url('../../images/pluto-images/img-sm-ball-vector.svg');
            background-repeat: no-repeat;
            background-size: cover;
            background-position: center;
            position: absolute;
            top: 50%;
            left: -5.125rem;
            width: 8.625rem;
            height: 8.625rem;
            display: inline-block;
            z-index: -1;
            animation: vector_floating_r 6s linear .3s infinite;

            @media (max-width: 992px) {
                width: 6rem;
                height: 6rem;
                left: -4.125rem;
                top: 40%;
            }

            @media (max-width: 992px) {
                width: 3.75rem;
                height: 3.75rem;
                top: 30%;
                left: -2.125rem;
            }
        }

        &::after {
            content: '';
            background-image: url('data:image/svg+xml,<svg width="225" height="100" viewBox="0 0 225 100" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M274.502 0.984486C246.226 6.02176 254.651 53.2741 226.375 58.3113C198.1 63.3486 189.675 16.0963 161.408 21.1384C133.133 26.1757 141.558 73.428 113.282 78.4653C85.0066 83.5025 76.5819 36.2503 48.3064 41.2875C20.0309 46.3248 28.4508 93.5859 0.175318 98.6231" stroke="rgb(250, 103, 58)" stroke-width="2" stroke-miterlimit="10" /> </svg> ');
            background-repeat: no-repeat;
            background-size: contain;
            background-position: center;
            position: absolute;
            top: 5rem;
            right: 0;
            width: 12.188rem;
            height: 13.75rem;
            display: inline-block;
            z-index: -1;
            animation: vector_floating_r 6s linear .3s infinite;

            @media (max-width: 992px) {
                top: 1rem;
                right: -3rem;
            }

            @media (max-width: 767px) {
                top: 1rem;
                right: -8rem;
            }
        }
    }
}

.block-footer-cta {
    &.without-title {
        background-position: center 2rem;

        @media (min-width: 768px) {
            background-position: center 0;
            background-size: 100%;
        }

    }

    &__content {
        @media (max-width: 992px) {
            margin-bottom: 3rem;
        }

        @media (max-width: 575px) {
            margin-bottom: 1.5rem;
        }
    }

    &__monkey {
        @media (max-width: 992px) {
            bottom: 5rem;
        }

        @media (max-width: 575px) {
            bottom: 3.5rem;
        }
    }
}

.block-footer-cta {
    background: transparent !important;
    margin-bottom: 4rem;

    .block-footer-cta__block {
        text-align: center;
        margin-top: 2rem;

        a {
            display: inline-flex;
        }
    }
}

// block-secure
.block-secure .block-secure__logo-link {
    box-shadow: transparent 0px 4px 0px 0px;
    transform: translateY(0);
    transition: transform 0.2s cubic-bezier(0.5, 2.5, 0.7, 0.7), box-shadow 0.2s cubic-bezier(0.5, 2.5, 0.7, 0.7), all 0.2s ease-in-out;

    &:hover,
    &:focus {
        transform: translateY(-0.25rem);
        box-shadow: rgba(0, 0, 0, 1) 0px 4px 0px 0px;
    }
}


// Blog Single
.single-content {
    color: var(--text-black);
    font-weight: 300;

    p {
        font-weight: 300;

        &:not(:last-child) {
            margin-bottom: 1.5rem;

            @media (max-width: 767px) {
                margin-bottom: 1.1rem;
            }
        }
    }


    h2,
    h3,
    h4,
    h5 {
        color: var(--text-black);
        margin-bottom: 1.5rem;
        font-weight: 500;

        @media (max-width: 767px) {
            margin-bottom: 1rem;
        }

        body.single &:not(:first-child) {
            margin-top: 3rem;
        }

        a {
            color: var(--text-black);
        }
    }

    h2,
    .h2 {
        font-size: clamp(1.375rem, 4.5vw, 2.25rem);
    }

    h3,
    .h3 {
        font-size: clamp(1.25rem, 4.5vw, 1.75rem);
    }

    h4,
    .h4 {
        font-size: clamp(1.125rem, 4.5vw, 1.375rem);
    }

    h6 {
        font-size: clamp(1rem, 2.5vw, 1.5rem);
        font-weight: 600;
        margin-bottom: 3.5rem;

        @media (max-width: 1200px) {
            margin-bottom: 2rem;
        }
    }

    strong {
        font-weight: 600;
    }

    ol:not(.splide__list),
    ul:not(.splide__list) {
        margin: 0 0 2rem;
        padding: 0;

        padding-left: 1.5rem;

        @media (max-width: 1200px) {
            margin-bottom: 1.25rem;
        }

        li {
            &:not(:last-child) {
                margin-bottom: 1rem;
            }

            ul,
            ol {
                margin: 1rem 0 1rem;
                padding: 0;
                padding-left: 1.5rem;
                font-size: 88%;

                li {
                    &:not(:last-child) {
                        margin-bottom: 0.5rem;
                    }

                }
            }
        }
    }

    ol:not(.splide__list) {
        list-style-type: decimal;

        li {
            list-style-type: decimal;

            &::marker {
                color: var(--black);
                font-weight: 400;
            }
        }
    }

    ul:not(.splide__list, .arrow-list) {
        list-style-type: disc;

        li {
            list-style-type: disc;

            &::marker {
                color: var(--black);
            }
        }
    }

    a {
        color: var(--red);
        text-decoration: underline;
        text-underline-offset: 5px;

        &>img {
            @include transition(0.3s, ease-in-out);
        }

        &:hover,
        &:focus {
            color: var(--dark-green);
            text-decoration: underline;

            &>img {
                opacity: 0.8;
            }
        }
    }

    u {
        text-decoration: underline;
        text-underline-offset: 5px;
    }

    body.single & img {
        width: auto;

        &.size-full {
            width: 100%;
        }

        @include border-radius(12px);
        -o-object-fit: cover;
        object-fit: cover;
        margin-bottom: 0;

        @media (max-width: 767px) {
            margin-bottom: 0;
        }
    }

    blockquote {
        border-left: 4px solid #FA673A;
        font-size: 1.25rem;
        line-height: 1.5;
        padding: 1rem 1.5rem;
        margin: 0;

        h2[id],
        h3[id] {
            padding-top: 0 !important;
            margin-top: 0 !important;
        }

        @media (max-width: 767px) {
            font-size: 1.1rem;
        }

        p {
            font-size: 1.5rem;
            font-weight: 600;
            margin-bottom: 0;

            @media (max-width: 767px) {
                font-size: 1rem;
            }
        }
    }

    img {
        margin-bottom: 2.5rem;
        border-radius: 10px;

        @media (max-width: 1200px) {
            margin-bottom: 2rem;
            margin-top: 0.8rem;
        }
    }

    figure {
        margin: 0px;
        padding: 0px;
    }

    .wp-caption {
        width: 100% !important;
        text-align: center;

        &.aligncenter {
            text-align: center;
        }

        &.alignleft {
            text-align: left;

            .wp-caption-text {
                text-align: left;
            }
        }

        &.alignright {
            text-align: right;

            .wp-caption-text {
                text-align: right;
            }
        }

        img {
            margin-bottom: 0.625rem;
            border-radius: 10px;
        }

        .wp-caption-text {
            text-align: center;
            font-size: 0.75rem;
            color: var(--dark-gray);
            padding-top: 0px;
            margin-bottom: 1.875rem;

            a {
                font-weight: 500;
            }
        }
    }

    table {
        border: 1px solid var(--black);
        padding: 0px;
        font-size: 1rem;
        border-collapse: collapse;
        text-align: left;
        margin-bottom: 1.375rem;
        width: 100%;

        tr {
            border-bottom: 1px solid var(--black);
        }

        th {
            font-weight: 600;
            padding: 5px 15px;
            background: var(--black);
            color: #fff;
            border-right: 1px solid var(--black);

            &:last-child {
                border-right: 0px;
            }
        }

        td {
            padding: 5px 15px;
            border: 1px solid var(--black);
            vertical-align: top;
        }

        ul {
            font-size: 14px;

            li {
                margin-bottom: 5px !important;
            }
        }
    }
}